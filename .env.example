PORT=4002
BACKEND_URL=http://localhost:4002

# Polymarket Data API key (optional — app uses public Gamma API by default)
POLYMARKET_DATA_API_KEY=pk_live_your_key_here
# POLYMARKET_USE_DATA_API=0
# POLYMARKET_PREDICTION_WEIGHT=0.65
# POLYMARKET_STATS_WEIGHT=0.6

# API-Football — real international player stats (https://www.api-football.com)
# Free tier: ~100 requests/day. Import caches responses under src/data/api-cache/
API_FOOTBALL_KEY=your_api_football_key_here
# npm run import:api-football -- --teams Morocco,Brazil
# npm run import:api-football -- --all

# Groq — free tier AI for Market Analyst tab (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
